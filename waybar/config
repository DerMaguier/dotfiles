[
    {
        "output": "DP-3", 
        "layer": "top",
        "position": "top",
        "height": 34,
        "spacing": 8,
        "exclusive": true,
        
        "modules-left": ["hyprland/workspaces", "custom/show_desktop", "wlr/taskbar"],
        "modules-center": [],
        
        "modules-right": ["tray", "network", "wireplumber#sink", "wireplumber#source", "clock"],

        "clock": {
            "format": "{:%a, %b %d %Y - %H:%M}",
            "tooltip-format": "<tt><small>{calendar}</small></tt>"
        },
        "wireplumber#sink": {
        "format": "{icon}  {volume}%",
        "format-muted": "󰖁 ",
        "format-icons": ["󰕿", "󰖀", "󰕾"],
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "scroll-step": 1,
        "max-volume": 100
        },
        "wireplumber#source": {
        "node-type": "Audio/Source",
        "format": "󰍬 {volume}%",
        "format-muted": "󰍭 ",
        "on-click": "pavucontrol -t 4",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "scroll-step": 1,
        "max-volume": 100
        },
       "network": {
       "format-wifi": "󰖩  {essid}",
       "format-ethernet": "󰈀 ",
       "format-disconnected": "󰤮 ",
       "tooltip-format": "IP: {ipaddr}\nPobieranie: {bandwidthDownBytes}\nWysyłanie: {bandwidthUpBytes}",
       "on-click": "nm-connection-editor" 
        },
        "wlr/taskbar": {
            "format": "{icon}",
            "icon-size": 18,
            "tooltip-format": "{title}",
            "on-click": "activate",
            "on-click-middle": "close"
        },
        "tray": {
            "icon-size": 18,
            "spacing": 10,
            "reverse-direction": true
        },
        "battery": {
            "states": {
                "warning": 30,
                "critical": 15
            },
            "format": "{icon} {capacity}%",
            "format-charging": "󰂄 {capacity}%",
            "format-plugged": "󰂄 {capacity}%",
            "format-icons": ["󰁺", "󰁼", "󰁾", "󰂀", "󰁹"]
        },
        "custom/show_desktop": {
            "format": "󰧨 ",
            "tooltip-format": "Czysty pulpit",
            "on-click": "hyprctl dispatch workspace empty"
        }
    },

    {
